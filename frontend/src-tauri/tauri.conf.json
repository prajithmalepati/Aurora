{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Aurora",
  "version": "0.1.0",
  "identifier": "app.aurora.music",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "nsis", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../backend/dist/aurora-backend/": "backend/"
    },
    "createUpdaterArtifacts": true,
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdFRDdGQTVGMjczRjA1QgpSV1JiOEhQeXBYL3RCKzU1VVNzb3hwUUluUCt4UExEQmNJczYxbWY1VmN4QmVFMWZyV1EyS3RRdAo=",
      "endpoints": [
        "https://github.com/prajithmalepati/Aurora/releases/latest/download/latest.json"
      ]
    }
  }
}
